<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         version="6.0">
  <display-name>Archetype Created Web Application</display-name>

  <servlet>
    <servlet-name>PostlyPageController</servlet-name>
    <servlet-class>com.victor.postlyweb.controllers.PostlyPageController</servlet-class>
    <multipart-config>
      <!-- aceita fotos de celular (ate 20 MB) -->
      <max-file-size>20971520</max-file-size>
      <max-request-size>22020096</max-request-size>
      <!-- threshold maior que o max mantem o upload em memoria e nao depende da
           pasta temporaria do servidor (que no Linux pode nao ser gravavel) -->
      <file-size-threshold>26214400</file-size-threshold>
    </multipart-config>
  </servlet>

  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/welcome</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/criar-conta</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/entrar</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/home</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/postar</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/editar-post</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/mensagens</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/chat</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/perfil</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/configuracoes</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/mudar-senha</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/post</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/auth/resolve-username</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/auth/check-username</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/auth/check-account</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/auth/session</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/auth/register</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/auth/google-complete</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PostlyPageController</servlet-name>
    <url-pattern>/auth/logout</url-pattern>
  </servlet-mapping>
</web-app>
